# Supabase — NEXT_PUBLIC_* vars are safe for client-side exposure.
# SUPABASE_SECRET_KEY must never be sent to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>
SUPABASE_SECRET_KEY=sb_secret_<your-key>

# Cron job authentication — generate with: openssl rand -hex 32
CRON_SECRET=<64-char-hex-secret>

# DEV API key for seeding (development only)
DEV_API_KEY=<your-dev-api-key>

# CORS — comma-separated allowed origins for /api/* routes.
# Set to your deployment origin (e.g. https://your-app.example.com).
# deploy.sh appends the Cloud Run service URL automatically after first deploy.
# Leave empty if you have no custom domain and will rely solely on the Cloud Run URL.
ALLOWED_ORIGINS=

# Custom domain for Cloud Run domain mapping.
# Set to your verified custom domain (e.g. your-app.example.com) or leave empty
# to skip the domain-mapping step in deploy.sh.
# Requires prior domain verification in Google Search Console:
#   https://search.google.com/search-console
CUSTOM_DOMAIN=
